# Ethereum Sepolia testnet RPC (default = publicnode; thay bằng Alchemy/Infura/QuickNode nếu bị rate-limit)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key của tài khoản dùng để triển khai hợp đồng (không commit vào repo, chỉ để ở local/.env)
# Lưu ý: Tài khoản này phải có đủ ETH trên Sepolia để trả phí gas
# Faucet: https://sepolia-faucet.pk910.de/  (PoW, không cần auth)
DEPLOYER_PRIVATE_KEY=


# API key của Etherscan để verify hợp đồng sau khi deploy 
# Đăng ký: https://etherscan.io/apis 
ETHERSCAN_API_KEY=
